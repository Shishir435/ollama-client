{
  "name": "olc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "olc": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run src/__tests__",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm -C ../.. exec biome check apps/cli",
    "lint:check": "pnpm -C ../.. exec biome check apps/cli",
    "lint:fix": "pnpm -C ../.. exec biome check apps/cli --write",
    "format": "pnpm -C ../.. exec biome format apps/cli",
    "format:check": "pnpm -C ../.. exec biome format apps/cli",
    "format:fix": "pnpm -C ../.. exec biome format apps/cli --write"
  },
  "dependencies": {
    "@olc/core": "workspace:*",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/react": "19.0.0",
    "tsx": "^4.20.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.14"
  }
}
