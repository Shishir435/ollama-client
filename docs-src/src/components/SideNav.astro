---
const normalizePath = (value: string) =>
  value === "/" ? "/" : value.replace(/\/$/, "")

const _currentPath = normalizePath(Astro.url.pathname)
---

<aside class="hidden w-64 shrink-0 border-r border-border bg-background md:block">
  <div class="flex h-full flex-col gap-6 px-6 py-8">
    {navSections.map((section) => (
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
          {section.title}
        </p>
        <ul class="mt-3 space-y-2 text-sm">
          {section.items.map((item) => {
            const isActive = currentPath === normalizePath(item.href)
            return (
              <li>
                <a
                  href={item.href}
                  class={`block rounded-lg px-3 py-2 transition ${
                    isActive
                      ? "bg-foreground text-background"
                      : "text-muted-foreground hover:bg-muted hover:text-foreground"
                  }`}
                >
                  {item.label}
                </a>
              </li>
            )
          })}
        </ul>
      </div>
    ))}
  </div>
</aside>
