{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/entrypoints/background.ts",
    "src/entrypoints/content.ts",
    "src/entrypoints/selection-button.content.tsx",
    "src/entrypoints/sidepanel/index.tsx",
    "src/entrypoints/options/index.tsx",
    "src/entrypoints/print/main.ts",
    "tools/*.ts",
    "wxt.config.ts",
    "vitest.config.ts"
  ],
  "project": ["src/**/*.{ts,tsx}", "tools/**/*.ts"],
  "ignore": ["docs/**", "src/i18n/resources.ts"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "tailwindcss",
    "tw-animate-css",
    "@tailwindcss/typography",
    "tailwind-scrollbar",
    "babel-plugin-react-compiler",
    "shadcn"
  ],
  "ignoreBinaries": ["preview"]
}
