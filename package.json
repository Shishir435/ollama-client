{
  "name": "ollama-client",
  "displayName": "Ollama Client - Chat with Local LLM Models",
  "version": "0.11.20",
  "description": "Local-first Chrome extension for private LLM chat with Ollama, LM Studio, llama.cpp, and other local/remote providers, including local RAG workflows.",
  "author": "Shishir Chaurasiya",
  "keywords": [
    "local llm chrome extension",
    "ollama client",
    "offline ai assistant",
    "ollama browser extension",
    "lm studio integration",
    "llama.cpp browser integration",
    "rag with local llms",
    "privacy-first ai",
    "local ai chat",
    "offline ai chat",
    "self-hosted ai",
    "private ai chat",
    "open-source ai",
    "browser ai assistant"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shishir435/ollama-client.git"
  },
  "homepage": "https://www.ollamaclient.in",
  "bugs": {
    "url": "https://github.com/Shishir435/ollama-client/issues"
  },
  "scripts": {
    "dev": "pnpm generate:resources && WXT_OUTPUT_DIR=build/chrome-mv3-dev wxt",
    "build": "pnpm generate:resources && WXT_OUTPUT_DIR=build/chrome-mv3-prod wxt build",
    "docs:dev": "pnpm docs:generate && pnpm --dir docs dev",
    "docs:build": "pnpm docs:generate && pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview",
    "docs:generate": "npx tsx tools/generate-docs.ts && npx tsx tools/generate-llms-docs.ts",
    "package": "pnpm generate:resources && WXT_OUTPUT_DIR=build/chrome-mv3-prod wxt zip",
    "dev:firefox": "pnpm generate:resources && WXT_OUTPUT_DIR=build/firefox-mv2-dev wxt -b firefox --mv2",
    "build:firefox": "pnpm generate:resources && WXT_OUTPUT_DIR=build/firefox-mv2-prod wxt build -b firefox --mv2 --mode production",
    "package:firefox": "pnpm generate:resources && WXT_OUTPUT_DIR=build/firefox-mv2-prod wxt zip -b firefox --mv2 --mode production",
    "verify:browser-smoke": "npx tsx tools/verify-browser-smoke.ts",
    "verify:local-browsers": "npx tsx tools/verify-local-browsers-sequential.ts",
    "verify:browser-automation": "pnpm verify:browser-smoke && npx tsx tools/verify-browser-automation-local.ts",
    "verify": "pnpm typecheck && pnpm lint:check && pnpm test:run && pnpm check:generated",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "lint:check": "biome check .",
    "test:related": "vitest related --run",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit": "pnpm audit",
    "clean": "rm -rf build .plasmo .wxt .output node_modules",
    "prepare": "husky && pnpm generate:resources",
    "generate:resources": "npx tsx tools/generate-i18n-resources.ts",
    "check:generated": "pnpm generate:resources && git diff --exit-code -- src/i18n/resources.ts public/_locales",
    "check:i18n": "npx tsx tools/check-i18n-drift.ts --strict"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@mozilla/readability": "^0.6.0",
    "@plasmohq/storage": "^1.15.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "d3-dsv": "^3.0.1",
    "defuddle": "0.9.0",
    "dexie": "^4.4.2",
    "dexie-export-import": "^4.4.0",
    "dompurify": "^3.4.5",
    "highlight.js": "^11.11.1",
    "hnsw": "^1.1.1",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "0.474.0",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-copy-code": "^0.1.3",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "minisearch": "^7.2.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^4.10.38",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-virtuoso": "^4.18.7",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "3.6.0",
    "tailwind-scrollbar": "^4.0.2",
    "turndown": "^7.2.4",
    "tweakpane": "^4.0.5",
    "vectra": "^0.11.1",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "0.0.258",
    "@types/d3-dsv": "^3.0.7",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^2.0.11",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/turndown": "^5.0.6",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "^4.1.7",
    "babel-plugin-react-compiler": "1.0.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.60.0",
    "postcss": "8.5.10",
    "rollup-plugin-visualizer": "^6.0.11",
    "shadcn": "^4.8.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7",
    "wxt": "^0.20.26"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "bash -lc \"pnpm typecheck\"",
      "pnpm format:fix",
      "pnpm lint:fix",
      "pnpm test:related"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=18"
  }
}
