{
  "name": "ollama-client-workspace",
  "private": true,
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "dev": "pnpm -C apps/extension dev",
    "build": "pnpm -C apps/extension build",
    "package": "pnpm -C apps/extension package",
    "dev:firefox": "pnpm -C apps/extension dev:firefox",
    "build:firefox": "pnpm -C apps/extension build:firefox",
    "package:firefox": "pnpm -C apps/extension package:firefox",
    "docs:dev": "pnpm -C apps/docs dev",
    "docs:build": "pnpm -C apps/docs build",
    "docs:preview": "pnpm -C apps/docs preview",
    "cli:dev": "pnpm -C apps/cli dev",
    "cli:build": "pnpm -C apps/cli build",
    "cli:start": "pnpm -C apps/cli start",
    "test": "pnpm -C apps/extension test",
    "test:run": "pnpm -C apps/extension test:run",
    "test:watch": "pnpm -C apps/extension test:watch",
    "test:coverage": "pnpm -C apps/extension test:coverage",
    "lint": "pnpm -r --if-present lint",
    "lint:check": "pnpm -r --if-present lint:check",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "format": "pnpm -r --if-present format",
    "format:check": "pnpm -r --if-present format:check",
    "format:fix": "pnpm -r --if-present format:fix",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -C apps/extension clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "bash -lc \"pnpm format:fix\"",
      "bash -lc \"pnpm lint:fix\"",
      "bash -lc \"pnpm typecheck\""
    ]
  }
}
