---
import { SITE_URL } from "@/seo/constants.mjs"

type StarlightHeadTag = {
  tag: "meta" | "link" | "script" | "style" | "title"
  attrs?: Record<string, string | number | boolean | undefined>
  content?: string
}

type StarlightRouteLocals = {
  starlightRoute: {
    head: StarlightHeadTag[]
    id: string
    entry: {
      data: {
        title: string
        description: string
      }
    }
    siteTitle: string
    lastUpdated?: Date
    lang: string
  }
}

const { head, id: slug, entry, siteTitle, lastUpdated, lang } =
  (Astro.locals as StarlightRouteLocals).starlightRoute

const base = Astro.site?.toString() ?? SITE_URL
const site = base.replace(/\/$/, "")
const ogUrl = `${site}/og/${slug}.png`
const pageUrl = `${site}/${slug}/`
const markdownUrl = `${site}/${slug}.md`

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  name: entry.data.title,
  description: entry.data.description,
  url: pageUrl,
  ...(lastUpdated && { dateModified: lastUpdated.toISOString() }),
  inLanguage: lang,
  isPartOf: {
    "@type": "WebSite",
    name: siteTitle,
    url: site,
  },
}
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
<meta property="og:image" content={ogUrl} />
<meta property="og:image:alt" content={entry.data.title} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:image" content={ogUrl} />
<meta name="twitter:image:alt" content={entry.data.title} />
<link rel="alternate" type="text/markdown" href={markdownUrl} />
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
