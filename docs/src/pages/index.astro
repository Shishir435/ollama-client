---
import BaseLayout from "@/layouts/BaseLayout.astro"
import {
  APP_VERSION,
  LANDING_TITLE,
  LANDING_DESCRIPTION,
  SITE_TITLE
} from "@/seo/constants.mjs"

const title = LANDING_TITLE
const description = LANDING_DESCRIPTION

const homepageFaq = [
  {
    question: "Does Ollama Client send chats to a cloud service?",
    answer:
      "No. Ollama Client stores chats and knowledge locally and sends model requests only to the provider endpoint you configure, including optional remote providers such as Anthropic."
  },
  {
    question: "Can I use Ollama Client with LM Studio or llama.cpp?",
    answer:
      "Yes. Ollama Client includes verified Ollama, LM Studio, and llama.cpp profiles, plus user-added OpenAI-compatible servers."
  },
  {
    question: "Is Ollama Client an Open WebUI alternative?",
    answer:
      "It can be, if you want a browser extension instead of a self-hosted web app. Ollama Client focuses on local-first chat, page context, files, web search, and browser tools inside Chrome or Firefox."
  }
]

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      name: SITE_TITLE,
      description,
      applicationCategory: "BrowserApplication",
      operatingSystem: "Chrome, Firefox",
      browserRequirements: "Chrome MV3 or Firefox MV2 compatible browser",
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD"
      },
      author: {
        "@type": "Person",
        name: "Shishir Chaurasiya",
        url: "https://www.shishirchaurasiya.in/"
      },
      url: "https://chromewebstore.google.com/detail/ollama-client-chat-with-l/bfaoaaogfcgomkjfbmfepbiijmciinjl",
      downloadUrl:
        "https://chromewebstore.google.com/detail/ollama-client-chat-with-l/bfaoaaogfcgomkjfbmfepbiijmciinjl",
      codeRepository: "https://github.com/Shishir435/ollama-client",
      softwareVersion: APP_VERSION
    },
    {
      "@type": "FAQPage",
      mainEntity: homepageFaq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer
        }
      }))
    }
  ]
}

const features = [
  {
    title: "Multi-provider local models",
    description:
      "Verified Ollama, LM Studio, and llama.cpp profiles, plus user-added OpenAI-compatible endpoints and Anthropic."
  },
  {
    title: "Multi-chat sessions",
    description:
      "Multiple concurrent chats with branch navigation and SQLite-backed local persistence."
  },
  {
    title: "Enhanced content extraction",
    description:
      "Defuddle integration with smart scroll strategies plus GitHub and YouTube extraction helpers."
  },
  {
    title: "Optional web search",
    description:
      "Tool-capable models can search through SearXNG, Brave Search, or Tavily while keeping backend choice in settings."
  },
  {
    title: "Text-to-speech",
    description:
      "Searchable voices, pitch and rate controls, per-message playback. Cross-browser voice loading."
  },
  {
    title: "Prompt templates",
    description:
      "Pre-built prompts for summarization, translation, and code help. Custom templates supported."
  },
  {
    title: "File upload & RAG",
    description:
      "PDF, TXT, MD, DOCX support with background embedding progress. Configurable max file size."
  },
  {
    title: "Backup & restore",
    description:
      "Full data snapshots via ZIP backups with versioned manifests. Restore reports partial failures."
  },
  {
    title: "Visible privacy controls",
    description:
      "Review local data, backup or wipe it, tag chats, and fork message branches without leaving the extension."
  },
  {
    title: "Advanced configuration",
    description:
      "Provider base URL control, selected model mapping, capability checks, debug logging."
  },
  {
    title: "Privacy first",
    description:
      "No mandatory cloud APIs. Local data storage. Open source. You control the endpoint."
  }
]

const stack = [
  "React 19",
  "WXT",
  "TypeScript",
  "shadcn/ui",
  "sql.js",
  "Defuddle"
]
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  {/* Hero */}
  <section class="border-b border-border/60 pb-20 pt-24 sm:pt-32">
    <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted-foreground">
      Local-first · v{APP_VERSION}
    </p>
    <h1
      class="mt-5 max-w-3xl text-balance text-4xl font-semibold leading-[1.1] tracking-tight sm:text-5xl"
    >
      Chat with local LLMs, right in your browser.
    </h1>
    <p class="mt-5 max-w-2xl text-balance text-[15px] leading-relaxed text-foreground/70">
      Ollama Client is an open-source browser extension for Ollama, LM Studio,
      llama.cpp, user-added OpenAI-compatible servers, and Anthropic.
      Chat with local AI models inside Chrome and Firefox with RAG, file upload,
      web search, tool calling, and page context — all without a mandatory cloud
      API.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a
        class="inline-flex h-9 items-center rounded-md bg-foreground px-4 text-sm font-medium text-background transition hover:bg-foreground/90"
        href="https://chromewebstore.google.com/detail/ollama-client-chat-with-l/bfaoaaogfcgomkjfbmfepbiijmciinjl"
        target="_blank"
        rel="noopener"
      >
        Install extension
      </a>
      <a
        class="inline-flex h-9 items-center rounded-md border border-border bg-background px-4 text-sm font-medium text-foreground transition hover:bg-muted"
        href="/guides/provider-setup/"
      >
        Read the setup guide
      </a>
      <a
        class="inline-flex h-9 items-center rounded-md px-4 text-sm font-medium text-foreground/70 transition hover:text-foreground"
        href="https://github.com/Shishir435/ollama-client"
        target="_blank"
        rel="noopener"
      >
        View source →
      </a>
    </div>
  </section>

  {/* Features */}
  <section class="border-b border-border/60 py-20">
    <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted-foreground">
      Features
    </h2>
    <p
      class="mt-3 max-w-2xl text-2xl font-semibold leading-snug tracking-tight"
    >
      What you can do without leaving your browser.
    </p>
    <div
      class="mt-12 grid grid-cols-1 gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3"
    >
      {features.map((feature) => (
        <div>
          <h3 class="text-[15px] font-medium tracking-tight">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-foreground/65">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </section>

  {/* Quickstart */}
  <section class="border-b border-border/60 py-20">
    <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted-foreground">
      Get started
    </h2>
    <p
      class="mt-3 max-w-2xl text-2xl font-semibold leading-snug tracking-tight"
    >
      Three steps from install to first chat.
    </p>
    <ol class="mt-12 grid grid-cols-1 gap-10 sm:grid-cols-3">
      <li>
        <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted-foreground">
          Step 1
        </span>
        <h3 class="mt-2 text-[15px] font-medium tracking-tight">
          Start a local provider
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-foreground/65">
          Run Ollama, LM Studio, or llama.cpp. Note the endpoint URL.
        </p>
      </li>
      <li>
        <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted-foreground">
          Step 2
        </span>
        <h3 class="mt-2 text-[15px] font-medium tracking-tight">
          Install the extension
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-foreground/65">
          Add it from the Chrome Web Store and pin it for easy access.
        </p>
      </li>
      <li>
        <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted-foreground">
          Step 3
        </span>
        <h3 class="mt-2 text-[15px] font-medium tracking-tight">
          Pick a model and chat
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-foreground/65">
          Open the side panel, pick a model, chat on any website. CORS issue?
          The setup guide covers it.
        </p>
      </li>
    </ol>
  </section>

  {/* Stack */}
  <section class="py-20">
    <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-muted-foreground">
      Stack
    </h2>
    <p class="mt-3 text-[15px] text-foreground/70">
      Built with
      <span class="text-foreground">{stack.join(" · ")}</span>.
    </p>
    <p class="mt-2 text-[15px] text-foreground/70">
      Endpoint privacy is yours to configure — see the
      <a class="underline decoration-border underline-offset-[3px] transition hover:decoration-foreground" href="/legal/privacy-policy/">
        privacy policy
      </a>
      for what stays local and what leaves.
    </p>
  </section>
</BaseLayout>
